# Copy this file to ".env" and fill in your real keys. The .env file is gitignored.

# Financial Modeling Prep (Starter plan) -- https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_key_here

# Unusual Whales API -- https://unusualwhales.com/public-api
UW_API_KEY=your_unusual_whales_token_here

# Anthropic API -- https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# GitHub Pages publishing.
# GH_TOKEN is only needed for LOCAL runs -- GitHub Actions provides it automatically
# via ${{ secrets.GITHUB_TOKEN }}, so it is never configured by hand in CI.
GH_TOKEN=your_personal_access_token_for_local_runs_only
REPO_OWNER=marcusrh12
REPO_NAME=swagaholicsflowscanner7540
PAGES_URL=https://marcusrh12.github.io/swagaholicsflowscanner7540
